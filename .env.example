# Render environment variables. Copy to .env for local dev (gitignored).

# Groq — powers /api/kit copy (Llama 3.3 70B). Free tier at console.groq.com.
# Without it, /api/kit still works: deterministic carts + templated copy.
GROQ_API_KEY=

# Anthropic — reserved for richer comparison verdicts (not required by /api/kit).
ANTHROPIC_API_KEY=

# Comma-separated allowlist of front-end origins permitted to call /api.
ALLOWED_ORIGINS=https://gymgearcompare.com,https://www.gymgearcompare.com

# Shared secret — must equal NEXT_PUBLIC_SITE_KEY on the frontend.
# Real value lives in Render env vars only — never commit one here.
SITE_KEY=
